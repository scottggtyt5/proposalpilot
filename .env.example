# Optional: OpenAI API Key for real proposal generation
# If not set, uses a sophisticated template-based fallback
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk_test_...

# Optional: Anthropic API Key as alternative to OpenAI
# If not set, uses a sophisticated template-based fallback
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Stripe Secret Key for payment processing
# If not set, checkout functionality will be disabled
# Get yours at: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_test_...

# Optional: Stripe Publishable Key (used client-side)
# Get yours at: https://dashboard.stripe.com/
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: Stripe Price IDs for products
# Create products/prices in Stripe dashboard
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_AGENCY=price_...

# Optional: Success/Cancel URLs for Stripe checkout
NEXT_PUBLIC_APP_URL=http://localhost:3000
