# Local development environment variables
# Copy this file to .env.local to use

# API Keys (Optional - app works without these)
OPENAI_API_KEY=sk_test_your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# Stripe (Optional - checkout disabled without these)
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key_here
STRIPE_PRICE_ID_PRO=price_1234567890
STRIPE_PRICE_ID_AGENCY=price_0987654321

# App URL (for local development)
NEXT_PUBLIC_APP_URL=http://localhost:3000
